# Salin file ini menjadi .env dan isi nilainya

# Port server backend
PORT=3000

# URL koneksi database MySQL
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE_NAME
DATABASE_URL="mysql://root:PASSWORD@localhost:3306/mobile_crud_db"

# Secret key JWT (ganti dengan string acak yang panjang dan kuat!)
JWT_SECRET="ganti-dengan-string-rahasia-yang-panjang-dan-kuat"
